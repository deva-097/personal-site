---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="inner">
    <p class="colophon">
      Set in <span>Fraunces</span> and <span>Inter</span>. Built slowly, in spare hours,
      inspired by <a href="https://henry.codes/writing/a-website-to-destroy-all-websites/" class="ink-link" target="_blank" rel="noreferrer">henry.codes</a>.
    </p>
    <p class="dateline">&copy; {year}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--rule);
  }

  .inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .inner {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
    }
  }

  .colophon {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    max-width: 36rem;
    margin: 0;
  }

  .colophon span { color: var(--foreground); }

  .meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .toggle {
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--muted-foreground);
    transition: color 0.2s;
  }

  .toggle:hover { color: var(--ink); }
</style>
