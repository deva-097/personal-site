    ]
  },
  ya: {
    id: "ya",
    title: "Other Favorites",
    subtitle: "Everything else that stayed.",
    books: [
      { title: "Harry Potter", author: "J.K. Rowling" },
      { title: "Matilda", author: "Roald Dahl" },
      { title: "Charlie and the Chocolate Factory", author: "Roald Dahl" },
      { title: "The Godfather", author: "Mario Puzo" },
      { title: "The Complete Sherlock Holmes", author: "Arthur Conan Doyle" },
      { title: "Shantaram", author: "Gregory David Roberts" },
      { title: "The Book Thief", author: "Markus Zusak" },
      { title: "Life of Pi", author: "Yann Martel" },
