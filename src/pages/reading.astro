---

<BaseLayout title="Reading | Devashish" description="Books I've read and recommendations">
  <div class="page-header">
    <p class="section-label">Reading</p>
    <h1>The long shelf, slowly built.</h1>
    <p class="header-intro">
      Reading has been a life-long companion. Introduced by my mom, encouraged by a couple of lovely people early on in life.
      Below is a collection of books I've loved best. Occasionally I'll post short write-ups and link them back.
      Full list on <a href="https://www.goodreads.com/devashish_097" target="_blank" rel="noopener noreferrer" class="ink-link">Goodreads</a>.
    </p>
  </div>

  <nav class="genre-nav">
    {Object.values(readingData).map((cat) => (
      <a href={`#${cat.id}`} class="pill">{cat.title}</a>
    ))}
  </nav>

  {Object.values(readingData).map((cat) => (
    <section class="category" id={cat.id}>
      <SectionLabel label={cat.title} subtitle={cat.subtitle} />
      <ul class="book-list">
        {cat.books.map((book) => (
          <li class="book-row">
            <p class="book-title">
              {book.link
                ? <a href={book.link}>{book.title}</a>
                : book.title
              }
              {book.note && <span class="book-note"> — {book.note}</span>}
            </p>
            <p class="book-author">{book.author}</p>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
  .page-header { margin-bottom: 2.5rem; }

  h1 {
    font-size: 2.5rem;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .header-intro {
    max-width: 38rem;
    color: var(--color-text);
    opacity: 0.85;
  }

  .genre-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .pill {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .pill:hover { color: var(--ink); border-color: var(--ink); }
  .pill.active { color: var(--color-bg); background-color: var(--color-text); border-color: var(--color-text); }

  .category { margin-bottom: 3.5rem; }
  .category.hidden { display: none; }

  .book-list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .book-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .book-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    margin: 0;
    line-height: 1.3;
  }

  .book-title a { color: var(--color-text); text-decoration: underline; text-underline-offset: 3px; }
  .book-title a:hover { color: var(--ink); }

  .book-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-family: var(--font-ui);
    font-style: normal;
  }

  .book-author {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-align: right;
    margin: 0;
    white-space: nowrap;
  }

  @media (max-width: 500px) {
    .book-row { grid-template-columns: 1fr; gap: 0.125rem; }
    .book-author { text-align: left; }
    h1 { font-size: 2rem; }
  }
</style>

<script>
  function filterGenres() {
    const hash = window.location.hash.slice(1);
    const categories = document.querySelectorAll('.category');
    const navLinks = document.querySelectorAll('.genre-nav a');

    navLinks.forEach(link => {
      link.classList.toggle('active', link.getAttribute('href')?.slice(1) === hash);
    });

    if (hash) {
      categories.forEach(cat => {
        cat.classList.toggle('hidden', cat.id !== hash);
      });
    } else {
      categories.forEach(cat => cat.classList.add('hidden'));
      navLinks.forEach(link => link.classList.remove('active'));
    }
  }

  document.querySelectorAll('.genre-nav a').forEach(link => {
    link.addEventListener('click', (e) => {
      if (link.getAttribute('href')?.slice(1) === window.location.hash.slice(1)) {
        e.preventDefault();
        history.replaceState(null, '', window.location.pathname);
        filterGenres();
      }
    });
  });

  filterGenres();
  window.addEventListener('hashchange', filterGenres);
</script>
