---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';

const readingData = {
  fantasy: {
    id: "fantasy",
    title: "Fantasy",
    subtitle: "High fantasy and the books that built the inner shelf.",
    books: [
      { title: "Realm of the Elderlings", author: "Robin Hobb", note: "15 books" },
      { title: "Malazan Book of the Fallen", author: "Steven Erikson", note: "10 books" },
      { title: "The Wheel of Time", author: "Robert Jordan", note: "14 books" },
      { title: "A Song of Ice and Fire", author: "George R.R. Martin" },
      { title: "The Stormlight Archive", author: "Brandon Sanderson" },
      { title: "The First Law Trilogy", author: "Joe Abercrombie" },
      { title: "Gentleman Bastard", author: "Scott Lynch" },
      { title: "The Broken Earth", author: "N.K. Jemisin" },
      { title: "The Inheritance Cycle", author: "Christopher Paolini" },
      { title: "The Lord of the Rings", author: "J.R.R. Tolkien" },
      { title: "The Hobbit", author: "J.R.R. Tolkien" },
      { title: "American Gods", author: "Neil Gaiman" },
      { title: "Norse Mythology", author: "Neil Gaiman" },
      { title: "Good Omens", author: "Terry Pratchett & Neil Gaiman" },
      { title: "A Wizard of Earthsea", author: "Ursula K. Le Guin" },
      { title: "Chronicles of The Black Company", author: "Glen Cook" },
    ]
  },
  scifi: {
    id: "scifi",
    title: "Science Fiction",
    subtitle: "Old futures and new ones.",
    books: [
      { title: "Foundation Series", author: "Isaac Asimov" },
      { title: "Hyperion Cantos", author: "Dan Simmons" },
      { title: "Remembrance of Earth's Past (The 3 Body Problem)", author: "Liu Cixin" },
      { title: "The Murderbot Diaries", author: "Martha Wells" },
      { title: "Project Hail Mary", author: "Andy Weir" },
      { title: "Ender's Game", author: "Orson Scott Card" },
      { title: "The Hitchhiker's Guide to the Galaxy", author: "Douglas Adams" },
      { title: "The Moon is a Harsh Mistress", author: "Robert A Heinlein", link: "/writing/reading-heinlein-ai" },
      { title: "1984", author: "George Orwell" },
      { title: "Brave New World", author: "Aldous Huxley" },
      { title: "Fahrenheit 451", author: "Ray Bradbury" },
      { title: "Neuromancer", author: "William Gibson" },
      { title: "I, Robot", author: "Isaac Asimov" },
    ]
  },
  nonfiction: {
    id: "nonfiction",
    title: "Non-Fiction",
    subtitle: "History, work, attention, sleep, money.",
    books: [
      { title: "Shoe Dog", author: "Phil Knight" },
      { title: "Working Backwards", author: "Colin Bryar" },
      { title: "Who: The A Method for Hiring", author: "Geoff Smart" },
      { title: "The Quarter-Life Breakthrough", author: "Adam Smiley Poswolsky" },
      { title: "Atomic Habits", author: "James Clear" },
      { title: "Deep Work", author: "Cal Newport" },
      { title: "The Psychology of Money", author: "Morgan Housel" },
      { title: "The Subtle Art of Not Giving a F*ck", author: "Mark Manson" },
      { title: "Wanting: Mimetic Desire", author: "Luke Burgis" },
      { title: "A Short History of Nearly Everything", author: "Bill Bryson" },
      { title: "Why We Sleep", author: "Matthew Walker" },
      { title: "Predictably Irrational", author: "Dan Ariely" },
