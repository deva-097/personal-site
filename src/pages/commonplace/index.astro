---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';

const pieces = await Astro.glob('../../content/commonplace/*.md');
const sortedPieces = pieces.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

const now = new Date();
const startOfYear = new Date(now.getFullYear(), 0, 1);
const weekNum = Math.floor((now.getTime() - startOfYear.getTime()) / (7 * 24 * 60 * 60 * 1000));
const featuredIdx = sortedPieces.length > 0 ? weekNum % sortedPieces.length : 0;
const featured = sortedPieces[featuredIdx];
const rest = sortedPieces.filter((_, i) => i !== featuredIdx);

const allTags = [...new Set(rest.flatMap(p => p.frontmatter.tags || []))].sort();
---

<BaseLayout title="Commonplace | Devashish" description="Collected poems, quotes, and fragments">
  <div class="page-header">
    <p class="section-label">A kept book</p>
    <h1>Commonplace</h1>
    <p class="hero-sub">Borrowed lines, fragments, and remembered passages I keep close.</p>
    <div class="header-body">
      <p>
        A <a href="https://en.wikipedia.org/wiki/Commonplace_book" target="_blank" rel="noopener" class="ink-link">commonplace book</a> is an old habit: a notebook where one copies down the lines, poems, and passages that earn a second reading. Mine has lived in margins, in apps, on scraps of paper. This is its public shelf.
      </p>
      <p>
        Poems, quotes, and fragments I've collected over the years: words that resonated best, parked here so you can enjoy them too.
      </p>
    </div>
  </div>

  {featured && (
    <>
      <SectionLabel label="Featured" />
      <div class="featured">
        <div class="featured-meta">
          <p class="smallcaps meta-author">{featured.frontmatter.author}</p>
          {(featured.frontmatter.tags || []).map((tag: string) => (
            <p class="smallcaps meta-tag">{tag}</p>
          ))}
        </div>
      <div class="featured-body">
        <h2 class="featured-title">
          <a href={`/commonplace/${featured.frontmatter.slug}`}>{featured.frontmatter.title}</a>
        </h2>
        {featured.frontmatter.description && (
          <p class="featured-excerpt dropcap">{featured.frontmatter.description}</p>
        )}
        <a href={`/commonplace/${featured.frontmatter.slug}`} class="continue-link">read entry &rarr;</a>
      </div>
    </div>
    </>
  )}

  <SectionLabel label="The whole notebook" subtitle="Every fragment, tagged and indexed." />

  {allTags.length > 0 && (
    <nav class="tag-nav">
      {allTags.map((tag) => (
        <a href={`#${tag}`} class="pill" data-tag={tag}>{tag}</a>
      ))}
    </nav>
  )}

  {rest.length > 0 ? (
    <ul class="piece-list">
      {rest.map((piece) => (
        <li data-tags={JSON.stringify(piece.frontmatter.tags || [])}>
          <a href={`/commonplace/${piece.frontmatter.slug}`} class="piece-row">
            <span class="piece-title">{piece.frontmatter.title}</span>
            <span class="piece-author">{piece.frontmatter.author}</span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">Collection coming soon.</p>
  )}
</BaseLayout>

<style>
  /* Hero */
  .page-header { margin-bottom: 4rem; }

  h1 {
    font-size: 3rem;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.375rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .header-body {
    max-width: 38rem;
    color: var(--color-text);
    opacity: 0.85;
  }

  /* Featured entry */
  .featured {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .featured-meta {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 9rem;
    padding-top: 0.35rem;
  }

  .meta-author { color: var(--color-text-muted); }
  .meta-tag    { color: var(--color-text-muted); }

  .featured-body { flex: 1; }

  .featured-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .featured-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .featured-title a:hover {
    color: var(--color-accent);
  }

  .featured-excerpt {
    font-family: var(--font-heading);
    font-style: italic;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .continue-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-accent);
  }

  .continue-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Tag filter */
  .tag-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .pill {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-accent);
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
  }

  .pill:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  .pill.active {
    color: var(--color-bg);
    background-color: var(--color-text);
    border-color: var(--color-text);
  }

  /* Archive list */
  .piece-list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .piece-list li { border-bottom: 1px solid var(--color-border); }
  .piece-list li.hidden { display: none; }

  .piece-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.85rem 0.5rem;
    margin: 0 -0.5rem;
    border-radius: 4px;
    color: var(--color-text);
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .piece-row:hover {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  .piece-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .piece-author {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .featured { flex-direction: column; gap: 1rem; }
    .featured-meta { flex-direction: row; flex-wrap: wrap; gap: 0.5rem; min-width: unset; }
    .piece-row { flex-direction: column; gap: 0.15rem; }
    .piece-author { white-space: normal; }
    h1 { font-size: 2.25rem; }
  }
</style>

<script>
  function filterPieces() {
    const hash = window.location.hash.slice(1);
    const items = document.querySelectorAll('.piece-list li');
    const pills = document.querySelectorAll('.tag-nav a');

    pills.forEach(pill => {
      pill.classList.toggle('active', (pill as HTMLElement).dataset.tag === hash);
    });

    if (hash) {
      items.forEach(item => {
        const tags = JSON.parse((item as HTMLElement).dataset.tags || '[]');
        item.classList.toggle('hidden', !tags.includes(hash));
      });
    } else {
      items.forEach(item => item.classList.remove('hidden'));
    }
  }

  document.querySelectorAll('.tag-nav a').forEach(pill => {
    pill.addEventListener('click', (e) => {
      if (pill.classList.contains('active')) {
        e.preventDefault();
        window.location.hash = '';
        filterPieces();
      }
    });
  });

  filterPieces();
  window.addEventListener('hashchange', filterPieces);
</script>
