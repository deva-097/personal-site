---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';

const categories = [
  {
    id: "historical-strategy",
    title: "Historical Strategy",
    subtitle: "Campaigns set against real history — these sparked a lasting interest in ancient civilisations and mythology.",
    intro: "It helped that most of them had a lot of background detail to read about the civilisations, the units, etc.",
    items: [
      { title: "Age of Empires II", notes: "Learned so much about the Huns, the Mongols, the Celts and the other races. Still sometimes view YT videos from gamers" },
      { title: "Age of Mythology", notes: "Greek, Egyptian, Norse gods. My entry point into mythology." },
      { title: "Rise of Nations" },
      { title: "Stronghold Crusader", notes: "Played an unreasonable amount of this." },
      { title: "Caesar 3, Pharoah", notes: "A different kind of city builder but fun nonetheless" },
    ]
  },
  {
    id: "rts",
    title: "RTS",
    subtitle: "Natural best-of of the RTS genre.",
    items: [
      { title: "Warcraft III (+ The Frozen Throne)", notes: "The primary one. All campaigns and expansions. The lore runs deep." },
      { title: "StarCraft II", notes: "Both Warcraft and Starcraft had such a great storyline, along with satisfying gameplay and varied races to dive into" },
    ]
  },
  {
    id: "adventure",
    title: "Action & Adventure",
    subtitle: "Great stories, brilliant gameplay and immersive, lovingly crafted worlds.",
    items: [
      { title: "Assassin's Creed", notes: "The OG" },
      { title: "Assassin's Creed: Ezio Trilogy", notes: "AC2, Brotherhood, Revelations. The geek in me was crying when I actually visited Florence." },
      { title: "Max Payne", notes: "The first one. Bullet time FTW" },
      { title: "God of War (2018 & Ragnarök)", notes: "Enjoyed these immensely despite not getting into the original series. Revisiting Norse mythology, the father-son dynamics and the story had me hooked." },
      { title: "Ghost of Tsushima", notes: "Scratched the Samurai / Ninja lover in me. Beautiful design and gameplay. Just the right amount of difficulty." },
    ]
  },
  {
    id: "rpg",
    title: "RPG",
    subtitle: "Immense lore, deep world-building — the same pull as a long book series with its own universe.",
    items: [
      { title: "The Elder Scrolls V: Skyrim", notes: "Fus-Ro-Dah! Right balance of customization and open-world helped this become a genre-defining game" },
      { title: "Dragon Age: Origins and Inquisition", notes: "The companions and their stories make this game stand out for me" },
      { title: "Breath of the Wild", notes: "Such a lovingly crafted game. My mind was blown once when I cut down a tree with a flaming sword — and instead of wood the game gave me a bonfire." },
    ]
  },
  {
    id: "comfort",
    title: "Comfort",
    subtitle: "Reliable retreats.",
    items: [
      { title: "Stardew Valley", notes: "A reliable retreat. Return to it from time to time." },
      { title: "RollerCoaster Tycoon", notes: "Absolute fun designing and maintaining parks. So many little mechanics packed into such a small game" },
    ]
  }
];
---

<BaseLayout title="Games | Devashish" description="Games I've loved">
  <div class="page-header">
    <p class="section-label">Gaming</p>
    <h1>Games, mythology, and history — the stories we keep retelling.</h1>
    <p class="header-intro">
      Games were my first window into history and mythology. The long campaigns of RTS and adventure games helped me spend hours learning without learning.
      These games pulled me in the same way long book series do — feeding a little bit of escapism, a lot of wonder, and a feeling of time well-spent.
    </p>
  </div>

  <nav class="genre-nav">
    {categories.map((cat) => (
      <a href={`#${cat.id}`} class="pill">{cat.title}</a>
    ))}
  </nav>

  {categories.map((cat) => (
    <section class="category" id={cat.id}>
      <SectionLabel label={cat.title} subtitle={cat.subtitle} />
      {cat.intro && <p class="cat-intro">{cat.intro}</p>}
      <ul class="game-list">
        {cat.items.map((item) => (
          <li class="game-row">
            <p class="game-title">{item.title}</p>
            {item.notes && <p class="game-note">{item.notes}</p>}
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
  .page-header { margin-bottom: 2.5rem; }

  h1 {
    font-size: 2.25rem;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .header-intro {
    max-width: 38rem;
    color: var(--color-text);
    opacity: 0.85;
  }

  .genre-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .pill {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-accent);
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .pill:hover { color: var(--ink); border-color: var(--ink); }
  .pill.active { color: var(--color-bg); background-color: var(--color-text); border-color: var(--color-text); }

  .category { margin-bottom: 4rem; }
  .category.hidden { display: none; }

  .cat-intro {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    margin-top: -1.5rem;
    max-width: 38rem;
  }

  .game-list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .game-row {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .game-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    margin: 0;
  }

  .game-note {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0.375rem 0 0;
  }

  @media (max-width: 500px) {
    h1 { font-size: 1.75rem; }
  }
</style>

<script>
  function filterCategories() {
    const hash = window.location.hash.slice(1);
    const categories = document.querySelectorAll('.category');
    const navLinks = document.querySelectorAll('.genre-nav a');

    navLinks.forEach(link => {
      link.classList.toggle('active', link.getAttribute('href')?.slice(1) === hash);
    });

    if (hash) {
      categories.forEach(cat => cat.classList.toggle('hidden', cat.id !== hash));
    } else {
      categories.forEach(cat => cat.classList.add('hidden'));
      navLinks.forEach(link => link.classList.remove('active'));
    }
  }

  document.querySelectorAll('.genre-nav a').forEach(link => {
    link.addEventListener('click', (e) => {
      if (link.getAttribute('href')?.slice(1) === window.location.hash.slice(1)) {
        e.preventDefault();
        history.replaceState(null, '', window.location.pathname);
        filterCategories();
      }
    });
  });

  filterCategories();
  window.addEventListener('hashchange', filterCategories);
</script>
