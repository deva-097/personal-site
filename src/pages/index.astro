---
import BaseLayout from '../layouts/BaseLayout.astro';

const today = new Date();
today.setHours(0, 0, 0, 0);
const posts = await Astro.glob('../content/writing/*.md');
const sortedPosts = posts
  .filter((p) => new Date(p.frontmatter.date) <= today)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 5);
---

<BaseLayout title="Devashish" wide={true}>
  <section class="intro">
    <div class="hero-image">
      <img src="/images/IMG_7512.jpg" alt="Vintage fountain pens — a Parker Vacumatic, a Pilot eyedropper, and a Swan lever filler" />
    </div>
    <p class="tagline">A reader-writer, father, collector of crafted things &mdash; <span class="tagline-accent">keeping a notebook in public.</span></p>
    <p class="greeting">Hello, I'm <strong>Devashish</strong>.</p>
    <p>
      I'm an engineer-MBA generalist in my professional life; and a doting father
      with a curious mind and many interests in my personal avatar. I like
      <a href="/reading">reading</a>, reflecting on the world and my place in it,
      collecting what I call <a href="/interests">"functional luxury" tools</a>,
      and traveling.
    </p>
    <p>
      I am on a quest to find more meaning in life, and will
      <a href="/writing">write</a> about whatever catches my fancy.
      Over the years I've saved a bunch of stuff that resonated with me, which I will
      keep <a href="/commonplace">publishing here</a>.
    </p>
    <p>
      I was inspired by <a href="https://henry.codes/writing/a-website-to-destroy-all-websites/" target="_blank">this piece</a>
      to finally take the plunge and put this site together.
    </p>
    <p>
      I like to dabble, so this may feel unconnected at first. This is my way of discovering
      myself. I hope you find something meaningful that resonates with you too.
    </p>
  </section>

  <section class="explore">
    <p class="section-label">The notebook</p>
    <div class="explore-rule"></div>

    <div class="explore-list">
      <div class="explore-item level-1">
        <h2 class="item-title"><a href="/writing">Meaning, attention, ambition</a></h2>
        <p class="item-desc">The slow questions of adulthood, written down in the hope of clearing them. <a href="/writing">writing &rarr;</a></p>
      </div>
      <div class="explore-item level-2">
        <h2 class="item-title"><a href="/commonplace">Borrowed lines</a></h2>
        <p class="item-desc">Things written by others, saved because they said it first, and better. <a href="/commonplace">commonplace &rarr;</a></p>
      </div>
      <div class="explore-item level-1">
        <h2 class="item-title"><a href="/reading">Books &amp; worlds</a></h2>
        <p class="item-desc">High fantasy, science fiction, the long shelf of books that built the inner shelf. <a href="/reading">reading &rarr;</a></p>
      </div>
      <div class="explore-item level-2">
        <h2 class="item-title"><a href="/interests">Objects &amp; functional luxury</a></h2>
        <p class="item-desc">Pens, knives, watches, wallets. Small well-made tools, kept and used. <a href="/interests">collections &rarr;</a></p>
      </div>
    </div>
  </section>

  <section class="recent">
    <p class="section-label">Recent writing</p>
    {sortedPosts.length > 0 ? (
      <ul class="post-list">
        {sortedPosts.map((post) => (
          <li>
            <a href={`/writing/${post.frontmatter.slug}`}>
              <span class="post-title">{post.frontmatter.title}</span>
              <span class="post-date">
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                  month: 'short',
                  year: 'numeric'
                })}
              </span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="no-posts">No posts yet. Check back soon!</p>
    )}
    <p class="see-all"><a href="/writing" class="ink-link">All essays &rarr;</a></p>
  </section>
</BaseLayout>

<style>
  section { margin-bottom: 3rem; }

  /* Intro */
  .intro { overflow: hidden; padding-top: 3rem; }

  .tagline {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .tagline-accent {
    color: var(--color-accent);
    font-style: italic;
  }

  .greeting {
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .greeting strong { font-weight: 600; }

  .hero-image {
    float: right;
    width: 310px;
    margin: 10rem 0 1rem 2rem;
  }

  .hero-image img {
    width: 100%;
    border-radius: 6px;
  }

  @media (max-width: 480px) {
    .hero-image { float: none; width: 100%; margin: 0 0 1.5rem 0; }
    .tagline { font-size: 1.6rem; }
  }

  /* Recurring Threads */
  .explore-rule {
    width: 3.5rem;
    height: 1px;
    background: var(--color-border);
    margin-bottom: 2.5rem;
  }

  .explore-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .explore-item { max-width: 36rem; }

  /* Alternating indentation */
  .level-1 { margin-left: 0; }
  .level-2 { margin-left: 3rem; }

  .item-title {
    font-size: 1.6rem;
    margin-bottom: 0.35rem;
    margin-top: 0;
    line-height: 1.2;
  }

  /* Level-2 items slightly smaller */
  .level-2 .item-title { font-size: 1.5rem; }

  .item-title a {
    color: var(--color-text);
    text-decoration: none;
  }
  .item-title a:hover { color: var(--color-accent); }

  .item-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .item-desc a { color: var(--color-accent); font-size: 0.85rem; }

  @media (max-width: 480px) {
    .level-2 { margin-left: 1.25rem; }
    .item-title { font-size: 1.35rem; }
    .level-2 .item-title { font-size: 1.15rem; }
  }

  /* Post list */
  .post-list { list-style: none; padding: 0; }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0.5rem;
    margin: 0 -0.5rem;
    border-radius: 4px;
    transition: background-color 0.15s ease;
    color: var(--color-text);
  }

  .post-list a:hover {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  .post-title { font-family: var(--font-heading); }

  .post-date {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .see-all {
    margin-top: 1rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    text-align: right;
  }
</style>
