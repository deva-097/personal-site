---
import BaseLayout from '../layouts/BaseLayout.astro';

// Get all posts from the content/writing folder
const today = new Date();
today.setHours(0, 0, 0, 0);
const posts = await Astro.glob('../content/writing/*.md');
const sortedPosts = posts
  .filter((p) => new Date(p.frontmatter.date) <= today)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 5); // Show up to 5 most recent posts
---

<BaseLayout title="Devashish">
  <section class="intro">
    <p class="greeting">Hello, I'm <strong>Devashish</strong>.</p>
    <p>
      I'm an engineer-MBA generalist in my professional life, and a doting father
      and a curious person with many interests in my personal avatar. I like
      <a href="/reading">reading</a>, reflecting on the world and my place in it,
      collecting what I call <a href="/interests">"functional luxury" tools</a>,
      and traveling.
    </p>
    <p>
      I am on a quest to find more meaning in life, and will
      <a href="/writing">write</a> about whatever catches my fancy.
      Over the years I've saved a bunch of stuff that resonated with me, which I will
      keep <a href="/commonplace">publishing here</a>.
    </p>
    <p>
      I was inspired by <a href="https://henry.codes/writing/a-website-to-destroy-all-websites/" target="_blank">this piece</a>
      to finally take the plunge and put this site together.
    </p>
    <p>
      I like to dabble, so this may feel unconnected at first. This is my way of discovering
      myself. I hope you find something meaningful that resonates with you too.
    </p>
  </section>

  <section class="explore">
    <h2>Explore</h2>
    <div class="explore-grid">
      <a href="/writing" class="explore-card">
        <span class="card-title">Writing</span>
        <span class="card-desc">Essays on whatever catches my fancy.</span>
        <span class="card-arrow">&rarr;</span>
      </a>
      <a href="/reading" class="explore-card">
        <span class="card-title">Reading</span>
        <span class="card-desc">High Fantasy, Sci-fi, and other loved books.</span>
        <span class="card-arrow">&rarr;</span>
      </a>
      <a href="/commonplace" class="explore-card">
        <span class="card-title">Commonplace</span>
        <span class="card-desc">Poems, quotes, and fragments I keep coming back to.</span>
        <span class="card-arrow">&rarr;</span>
      </a>
      <a href="/interests" class="explore-card">
        <span class="card-title">Collections</span>
        <span class="card-desc">Functional luxury things that I collect (and occasionally hoard).</span>
        <span class="card-arrow">&rarr;</span>
      </a>
    </div>
  </section>

  <section class="recent">
    <h2>Recent Writing</h2>
    {sortedPosts.length > 0 ? (
      <ul class="post-list">
        {sortedPosts.map((post) => (
          <li>
            <a href={`/writing/${post.frontmatter.slug}`}>
              <span class="post-title">{post.frontmatter.title}</span>
              <span class="post-date">
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                  month: 'long',
                  year: 'numeric'
                })}
              </span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="no-posts">No posts yet. Check back soon!</p>
    )}
    <p class="see-all"><a href="/writing">See all &rarr;</a></p>
  </section>
</BaseLayout>

<style>
  .intro {
    margin-bottom: 2rem;
  }

  .greeting {
    font-size: 1.25rem;
  }

  .greeting strong {
    font-weight: 600;
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list li {
    margin-bottom: 0;
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 6px;
    transition: background-color 0.15s ease;
  }

  .post-list a:hover {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  .post-list a:hover .post-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-title {
    font-family: var(--font-heading);
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .see-all {
    margin-top: 1rem;
  }

  .see-all a {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .explore {
    margin-bottom: 2.5rem;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .explore-card {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: background-color 0.15s ease, border-color 0.15s ease;
    color: var(--color-text);
  }

  .explore-card:hover {
    background-color: var(--color-surface);
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    flex: 1;
  }

  .card-arrow {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
    transition: color 0.15s ease;
  }

  .explore-card:hover .card-arrow {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .explore-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
