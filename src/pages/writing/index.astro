---
import BaseLayout from '../../layouts/BaseLayout.astro';

const today = new Date();
today.setHours(0, 0, 0, 0);
const posts = await Astro.glob('../../content/writing/*.md');
const sortedPosts = posts
  .filter((p) => new Date(p.frontmatter.date) <= today)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const featured = sortedPosts[0];
const rest = sortedPosts.slice(1);
---

<BaseLayout title="Writing | Devashish" description="Essays and thoughts">
  <p class="section-label">Writing</p>
  <p class="page-intro">Essays, in no particular order.</p>
  <hr class="intro-rule" />

  {featured && (
    <div class="featured">
      <div class="featured-meta">
        <p class="smallcaps meta-label">Featured</p>
        <p class="smallcaps meta-date">
          {new Date(featured.frontmatter.date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
        </p>
        {(featured.frontmatter.tags || []).map((tag: string) => (
          <p class="smallcaps meta-tag">{tag}</p>
        ))}
      </div>
      <div class="featured-body">
        <h2 class="featured-title">
          <a href={`/writing/${featured.frontmatter.slug}`}>{featured.frontmatter.title}</a>
        </h2>
        {featured.frontmatter.description && (
          <p class="featured-excerpt dropcap">{featured.frontmatter.description}</p>
        )}
        <a href={`/writing/${featured.frontmatter.slug}`} class="continue-link">continue reading &rarr;</a>
      </div>
    </div>
  )}

  {rest.length > 0 && (
    <ul class="post-list">
      {rest.map((post) => (
        <li>
          <a href={`/writing/${post.frontmatter.slug}`}>
            <span class="post-title">{post.frontmatter.title}</span>
            <span class="post-date">
              {new Date(post.frontmatter.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}

  <p class="see-all"><a href="/writing" class="ink-link">All essays &rarr;</a></p>
</BaseLayout>

<style>
  .page-intro {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .intro-rule {
    margin: 1.5rem 0 2.5rem;
  }

  /* Featured essay */
  .featured {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .featured-meta {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 9rem;
    padding-top: 0.35rem;
  }

  .meta-label { color: var(--color-text-muted); }
  .meta-date  { color: var(--color-text-muted); }
  .meta-tag   { color: var(--color-text-muted); }

  .featured-body { flex: 1; }

  .featured-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .featured-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .featured-title a:hover {
    color: var(--color-accent);
  }

  .featured-excerpt {
    font-family: var(--font-heading);
    font-style: italic;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .continue-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-accent);
  }

  .continue-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Post list */
  .post-list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .post-list li {
    border-bottom: 1px solid var(--color-border);
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 0.5rem;
    margin: 0 -0.5rem;
    border-radius: 4px;
    transition: background-color 0.15s ease;
    color: var(--color-text);
  }

  .post-list a:hover {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  .post-title {
    font-family: var(--font-heading);
  }

  .post-date {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .see-all {
    margin-top: 2rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    text-align: right;
  }

  @media (max-width: 600px) {
    .featured { flex-direction: column; gap: 1rem; }
    .featured-meta { flex-direction: row; flex-wrap: wrap; gap: 0.5rem; min-width: unset; }
  }
</style>
