---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';

const interests = {
  edc: {
    id: "edc",
    title: "Knives, EDC & Wallets",
    subtitle: "Swiss knives were my first obsession — multi-functional, well-designed, built to last.",
    description: "Swiss knives were my first obsession - multi-functional, well-designed, built to last. Led me down into a deeper EDC rabbithole.",
    items: [
      { brand: "Victorinox", links: [
        { name: "Tinker", url: "https://www.victorinox.com/en/Products/Swiss-Army-Knife%E2%84%A2-and-Tools/Essentials/Tinker/p/1.4603" },
        { name: "Spartan", url: "https://www.victorinox.com/en/Products/Swiss-Army-Knife%E2%84%A2-and-Tools/Essentials/Spartan/p/1.3603" },
        { name: "Evolution 14 Wood", url: "https://www.victorinox.com/en-KR/Products/Swiss-Army-Knife%E2%84%A2-and-Tools/Outdoor/Evolution-17-Wood/p/2.3911.63" },
      ], notes: "Went a little overboard hoarding them for different places"},
      { name: "Tenacious", brand: "Spyderco", url: "https://spyderco.com/products/c122g-tenacious%C2%AE?variant=44049535696940", notes: "First one after actually exploring EDC knives" },
      { name: "No.8 Carbon", brand: "Opinel", url: "https://www.opinel.com/en/pocket-knives/carbone/n8-carbon", notes: "One of the modern classics." },
      { name: "i3T 2", brand: "Olight", url: "https://www.olight.com/store/i3t-2-small-edc-flashlight", notes: "EDC flashlight" },
      { name: "Dime", brand: "Gerber", url: "https://www.gerbergear.com/en-us/shop/multi-tools/all-multi-tools/dime-black-30-000469n", notes: "Lost at BLR airport security" },
      { name: "Miniwallet Original", brand: "Secrid", url: "https://secrid.com/en-global/miniwallet-original-chocolate/", notes: "Highly recommend some version of this" },
      { name: "Altitude Billfold", brand: "Pioneer", url: "https://pioneercarry.com/collections/wallets/products/altitude-billfold", notes: "My first kickstarter purchase" },
      { name: "Classic Wallet (Ikat Blue)", brand: "Nappadori", url: "https://www.nappadori.com/collections/wallets/products/classic-wallet-ikat", notes: "Gifted. Perfect blend of Indian aesthetic and good functionality" }
    ]
  },
  watches: {
    id: "watches",
    title: "Watches",
    subtitle: "Graduated slowly from a kid G-Shock to an Omega. The Aqua Terra made me feel done.",
    description: "Graduated slowly from kid G-Shock (with the rooster alarm) in school to an Omega now. At one point my wishlist had about 30 watches on it and worth about $2Mn. But the Aqua Terra made me feel 'done' - a true GADA watch.",
    items: [
      { name: "Seamaster Aqua Terra", brand: "Omega", url: "https://www.omegawatches.com/watch-omega-seamaster-aqua-terra-150m-co-axial-master-chronometer-41-mm-22010412103004", notes: "The GADA watch" },
      { name: "Prospex Alpinist", brand: "Seiko", url: "https://www.seikowatches.com/in-en/products/prospex/spb121j1", notes: "Gifted, true strap monster" },
      { name: "Seamaster ST 166-0209 (Vintage)", brand: "Omega", url: "https://www.omegawatches.com/watch-omega-seamaster-omega-st-166-0209", notes: "Don't know the story behind this one unfortunately" },
      { name: "6M13 Age of Discovery", brand: "Seiko", url: "https://www.reddit.com/r/Watches/comments/be4r0d/seiko_6m13_age_of_discovery_perpetual_calendar/", notes: "Lying out of commission. Need to find someone I trust enough to repair it" },
      { name: "Couturier Chronograph", brand: "Tissot", url: "https://zimsonwatches.com/products/tissot-t-classic-silver-dial-men-41mm-t0356171103100", notes: "Gifted. First expensive watch that kicked off the rest of the collection" },
      { name: "Metric Retro Black", brand: "Brew", url: "https://www.brew-watches.com/products/brew-metric-retro-black" },
      { brand: "Mr Jones", links: [
        { name: "A Perfectly Useless Afternoon", url: "https://mrjoneswatches.com/collections/all-watches/products/a-perfectly-useless-afternoon" },
        { name: "Paper Crane", url: "https://mrjoneswatches.com/products/paper-crane" },
      ], notes: "Fun and quirky."},
      { name: "INOX", brand: "Victorinox", url: "https://www.victorinox.com/en/Products/Watches/Men's-Watches/INOX/p/241682.1", notes: "Built like a tank, mine's on a paracord strap" },
      { name: "Raketa 24hr watch", brand: "Raketa", url: "https://vintagewatchinc.com/24-hour-watch/", notes: "Such a cool looking watch! For some reason I always forget it has manual winding" },
    ]
  },
  fountainPens: {
    id: "fountain-pens",
    title: "Fountain Pens",
    subtitle: "Recovering addict. From a Lamy Safari in school to 25+ pens at one point.",
    description: "Recovering fountain pen addict. From a Lamy Safari in school to 25+ pens at one point. Ran the gauntlet on different filling systems, grinds, nibs, custom pens, inks, leather holders — Diderot effect in full glory.",
    items: [
      { name: "2000", brand: "Lamy", url: "https://www.lamy.com/en-us/p/lamy-2000-fountain-pen/52875809096014" },
      { name: "3776 Century (Chartres Blue)", brand: "Platinum", url: "https://www.gouletpens.com/products/platinum-3776-century-fountain-pen-chartres-blue-gold" },
      { name: "Carène Deluxe", brand: "Waterman", url: "https://www.waterman.com/pens/car%C3%A8ne/car%C3%A8ne-deluxe-fountain-pen/SP_1912425.html" },
      { name: "1911 Large (Black/Silver)", brand: "Sailor", url: "https://goldspot.com/products/sailor-1911-large-fountain-pen-in-black-with-silver-trim-21k-gold" },
      { name: "Custom 823 (Amber Brown)", brand: "Pilot", url: "https://makoba.com/products/pilot-custom-823-fountain-pen-amber-brown-gt" },
      { name: "Safari (Umbra)", brand: "Lamy", url: "https://makoba.com/products/lamy-safari-fountain-pen-umbra" },
      { name: "Starwalker Ultrablack", brand: "Montblanc", url: "https://www.gioiellerialucchese.it/en/writing-pens/19971-montblanc-starwalker-ultrablack-fountain-pen-126339.html" },
      { name: "Beatles LE", brand: "Montblanc" },
      { name: "Several vintage pens", brand: "Various" }
    ],
    diderot: true
  },
  coffee: {
    id: "coffee",
    title: "Coffee",
    subtitle: "French press most mornings. Thogarihunkal Estate beans, Blue Tokai's birthday blends.",
    description: "Brew a french press most days in the morning. My favorite beans: anything from Thogarihunkal Estate (any roaster), and Blue Tokai's annual birthday blends.",
    items: [
      { name: "Encore Grinder", brand: "Baratza", url: "https://www.baratza.com/en-us/product/encore-zcg485" },
      { name: "Cold Brew Pot", brand: "Hario", url: "https://global.hario.com/product/coffee/coldbrew/MCPN.html" },
      { name: "Chestnut C2 Grinder", brand: "Timemore", url: "https://toffeecoffeeroasters.com/collections/timemore/products/timemore-chestnut-c2-grinder" },
      { name: "Steel French Press", brand: "Generic", url: "https://www.amazon.in/dp/B09MHWWGH9", notes: "After breaking 3 glass ones" },
      { name: "Rambler 20oz", brand: "Yeti", url: "https://www.yeti.com/drinkware/tumblers/21071502223.html", notes: "Gift from the wife" }
    ]
  }
};
---

<BaseLayout title="Collections | Devashish" description="Things I care about">
  <div class="page-header">
    <p class="section-label">Collections</p>
    <h1>Functional luxuries.</h1>
    <p class="header-intro">
      A collection of things that bring me joy or occupy my attention — objects, hobbies, and obsessions, documented for my own reference and anyone else who might share these interests. I can talk for hours on any of these.
    </p>
  </div>

  <nav class="interest-nav">
    <a href="#edc" class="pill">Knives, EDC & Wallets</a>
    <a href="#watches" class="pill">Watches</a>
    <a href="#fountain-pens" class="pill">Fountain Pens</a>
    <a href="#coffee" class="pill">Coffee</a>
  </nav>

  {Object.values(interests).map((cat) => (
    <section class="interest-section" id={cat.id}>
      <SectionLabel label={cat.title} subtitle={cat.subtitle} />
      {cat.id === 'fountain-pens' ? (
        <p class="section-desc">Recovering fountain pen addict. From a Lamy Safari in school to 25+ pens at one point. Ran the gauntlet on different filling systems, grinds, nibs, custom pens, inks, leather holders — <a href="/writing/things-that-own-you" class="ink-link">Diderot effect</a> in full glory.</p>
      ) : (
        <p class="section-desc">{cat.description}</p>
      )}
      <ul class="item-list">
        {cat.items.map((item) => (
          <li class="item-row">
            <p class="item-name">
              {item.links ? (
                item.links.map((link, i) => (
                  <>{i > 0 && <span class="item-sep">, </span>}<a href={link.url} target="_blank" rel="noopener noreferrer">{link.name}</a></>
                ))
              ) : item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer">{item.name}</a>
              ) : (
                item.name
              )}
              {item.notes && <span class="item-note"> — {item.notes}</span>}
            </p>
            <p class="item-brand">{item.brand}</p>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
  .page-header { margin-bottom: 2.5rem; }

  h1 {
    font-size: 2.5rem;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .header-intro {
    max-width: 38rem;
    color: var(--color-text);
    opacity: 0.85;
  }

  .interest-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .pill {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-accent);
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .pill:hover { color: var(--ink); border-color: var(--ink); }
  .pill.active { color: var(--color-bg); background-color: var(--color-text); border-color: var(--color-text); }

  .interest-section { margin-bottom: 4rem; }
  .interest-section.hidden { display: none; }

  .section-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    max-width: 38rem;
  }

  .item-list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .item-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .item-name {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    margin: 0;
    line-height: 1.4;
  }

  .item-name a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .item-name a:hover { color: var(--ink); }

  .item-note {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .item-sep { color: var(--color-text-muted); }

  .item-brand {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-align: right;
    margin: 0;
    white-space: nowrap;
  }

  @media (max-width: 500px) {
    .item-row { grid-template-columns: 1fr; gap: 0.125rem; }
    .item-brand { text-align: left; }
    h1 { font-size: 2rem; }
  }
</style>

<script>
  function filterSections() {
    const hash = window.location.hash.slice(1);
    const sections = document.querySelectorAll('.interest-section');
    const navLinks = document.querySelectorAll('.interest-nav a');

    navLinks.forEach(link => {
      link.classList.toggle('active', link.getAttribute('href')?.slice(1) === hash);
    });

    if (hash) {
      sections.forEach(s => s.classList.toggle('hidden', s.id !== hash));
    } else {
      sections.forEach(s => s.classList.add('hidden'));
      navLinks.forEach(link => link.classList.remove('active'));
    }
  }

  document.querySelectorAll('.interest-nav a').forEach(link => {
    link.addEventListener('click', (e) => {
      if (link.getAttribute('href')?.slice(1) === window.location.hash.slice(1)) {
        e.preventDefault();
        history.replaceState(null, '', window.location.pathname);
        filterSections();
      }
    });
  });

  filterSections();
  window.addEventListener('hashchange', filterSections);
</script>
